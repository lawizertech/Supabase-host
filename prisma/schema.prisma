generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters", "multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model services {
  id                  String    @id
  service_id          String    @unique
  title               String
  subtitle            String?
  badge_text          String?
  icon                String?
  content_title       String?
  content_description String?
  section1_title      String?
  price               Float?
  original_price      Float?
  theme               Json?
  primary_color       String?
  primary_bg          String?
  primary_hover_bg    String?
  benefits            Json?
  faqs                Json?
  sections            Json?
  addons              Json?
  category            String?
  is_active           Boolean   @default(true)
  created_at          DateTime? @default(now())
  updated_at          DateTime?

  @@schema("public")
}

model profiles {
  id                  String    @id @db.Uuid
  role                String    @default("client")
  name                String?
  email               String?
  phone               String?
  professional_status String?
  city                String?
  state               String?
  created_at          DateTime? @default(now())
  updated_at          DateTime? @default(now())

  cases_as_client       cases[]              @relation("cases_client_idToprofiles")
  cases_as_professional cases[]              @relation("cases_professional_idToprofiles")
  call_events           call_events[]
  call_participants     call_participants[]
  calls_initiated       calls[]              @relation("calls_initiated_byToprofiles")
  calls_accepted        calls[]              @relation("calls_accepted_byToprofiles")
  case_documents        case_documents[]
  case_timeline         case_timeline[]
  chat_messages         chat_messages[]
  meeting_participants  meeting_participants[]
  notifications         notifications[]
  admin_audit_log       admin_audit_log[]

  @@schema("public")
}

model cases {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id       String    @db.Uuid
  professional_id String?   @db.Uuid
  case_type       String
  status          String    @default("created")
  metadata        Json?     @default("{}")
  created_at      DateTime? @default(now())
  updated_at      DateTime? @default(now())

  client       profiles  @relation("cases_client_idToprofiles", fields: [client_id], references: [id], onDelete: Cascade)
  professional profiles? @relation("cases_professional_idToprofiles", fields: [professional_id], references: [id])

  calls          calls[]
  case_documents case_documents[]
  case_timeline  case_timeline[]
  chat_messages  chat_messages[]
  meetings       meetings[]
  payments       payments[]

  @@index([client_id])
  @@index([professional_id])
  @@index([status])
  @@schema("public")
}

model calls {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id          String    @db.Uuid
  initiated_by     String    @db.Uuid
  mode             String
  accepted_by      String?   @db.Uuid
  status           String    @default("ringing")
  started_at       DateTime? @default(now())
  connected_at     DateTime?
  ended_at         DateTime?
  end_reason       String?
  livekit_room_name String?
  recording_enabled Boolean? @default(false)
  created_at       DateTime? @default(now())

  case                                  cases               @relation(fields: [case_id], references: [id], onDelete: Cascade)
  initiator                             profiles            @relation("calls_initiated_byToprofiles", fields: [initiated_by], references: [id], onDelete: Cascade)
  acceptor                              profiles?           @relation("calls_accepted_byToprofiles", fields: [accepted_by], references: [id])
  call_events                           call_events[]
  call_participants                     call_participants[]
  call_recordings                       call_recordings[]

  @@index([case_id])
  @@index([initiated_by])
  @@index([status])
  @@schema("public")
}

model call_events {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  call_id    String    @db.Uuid
  event_type String
  actor_id   String?   @db.Uuid
  metadata   Json?     @default("{}")
  created_at DateTime? @default(now())

  call    calls     @relation(fields: [call_id], references: [id], onDelete: Cascade)
  profile profiles? @relation(fields: [actor_id], references: [id])

  @@index([call_id])
  @@schema("public")
}

model call_participants {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  call_id    String    @db.Uuid
  profile_id String    @db.Uuid
  role       String?   @default("participant")
  joined_at  DateTime?
  left_at    DateTime?
  created_at DateTime? @default(now())

  call    calls    @relation(fields: [call_id], references: [id], onDelete: Cascade)
  profile profiles @relation(fields: [profile_id], references: [id])

  @@unique([call_id, profile_id])
  @@index([call_id])
  @@schema("public")
}

model call_recordings {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  call_id            String    @db.Uuid
  storage_path       String
  duration_seconds   Int?
  file_size_bytes    BigInt?
  encryption_key_ref String?
  status             String?   @default("recording")
  created_at         DateTime? @default(now())

  call calls @relation(fields: [call_id], references: [id], onDelete: Cascade)

  @@index([call_id])
  @@schema("public")
}

model case_documents {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id      String    @db.Uuid
  uploaded_by  String?   @db.Uuid
  storage_path String
  filename     String?
  file_type    String?
  size_bytes   BigInt?
  created_at   DateTime? @default(now())

  case    cases     @relation(fields: [case_id], references: [id], onDelete: Cascade)
  profile profiles? @relation(fields: [uploaded_by], references: [id])
  chat_messages chat_messages[]

  @@index([case_id])
  @@schema("public")
}

model case_timeline {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id     String    @db.Uuid
  actor_id    String?   @db.Uuid
  from_status String?
  to_status   String?
  note        String?
  created_at  DateTime? @default(now())

  case    cases     @relation(fields: [case_id], references: [id], onDelete: Cascade)
  profile profiles? @relation(fields: [actor_id], references: [id])

  @@index([case_id])
  @@schema("public")
}

model chat_messages {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id        String          @db.Uuid
  sender_id      String?         @db.Uuid
  text           String?
  attachment_ref String?         @db.Uuid
  created_at     DateTime?       @default(now())
  read_at        DateTime?

  case       cases           @relation(fields: [case_id], references: [id], onDelete: Cascade)
  sender     profiles?       @relation(fields: [sender_id], references: [id])
  attachment case_documents? @relation(fields: [attachment_ref], references: [id])

  @@index([case_id])
  @@schema("public")
}

model meetings {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id       String    @db.Uuid
  title         String    @default("Consultation")
  scheduled_for DateTime?
  start_time    DateTime?
  end_time      DateTime?
  status        String?   @default("proposed")
  meeting_link  String?
  created_at    DateTime? @default(now())

  case                 cases                  @relation(fields: [case_id], references: [id], onDelete: Cascade)
  meeting_participants meeting_participants[]

  @@index([case_id])
  @@schema("public")
}

model meeting_participants {
  meeting_id String @db.Uuid
  profile_id String @db.Uuid
  role       String? @default("attendee")

  meeting  meetings @relation(fields: [meeting_id], references: [id], onDelete: Cascade)
  profile  profiles @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@id([meeting_id, profile_id])
  @@schema("public")
}

model payments {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id             String    @db.Uuid
  razorpay_order_id   String?
  razorpay_payment_id String?   @unique
  status              String?
  amount              Decimal?  @db.Decimal(12, 2)
  verified_at         DateTime?
  raw_webhook_payload Json?
  refund_status       String?
  refund_id           String?
  created_at          DateTime? @default(now())

  case cases @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id])
  @@schema("public")
}

model notifications {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipient_id String    @db.Uuid
  type         String
  payload      Json      @default("{}")
  read_at      DateTime?
  created_at   DateTime? @default(now())

  recipient profiles @relation(fields: [recipient_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

model admin_audit_log {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_id   String    @db.Uuid
  action     String
  target_id  String?
  metadata   Json?     @default("{}")
  created_at DateTime? @default(now())

  actor profiles @relation(fields: [actor_id], references: [id])

  @@schema("public")
}

model reconciliation_log {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  run_at              DateTime? @default(now())
  orders_checked      Int
  discrepancies_found Int
  auto_healed         Int
  metadata            Json?     @default("{}")

  @@schema("public")
}
